{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["status-server", "prometheus"],
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "title": "Status Server Live Values",
  "uid": "status-server-live-values",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "alias",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(control_system_attribute_age_seconds, alias)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Alias"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Current Values Snapshot",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_age_seconds",
          "refId": "A",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "expr": "control_system_attribute_value",
          "refId": "B",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "alias",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "source": true, "source 1": true, "source 2": true,
              "name": true, "name 1": true, "name 2": true,
              "attribute": true, "attribute 1": true, "attribute 2": true,
              "device 1": true
            },
            "indexByName": {
              "alias":   0,
              "device":  1,
              "Value 1": 2,
              "Value":   3
            },
            "renameByName": {
              "alias":   "Alias",
              "device":  "Device",
              "Value 1": "Value",
              "Value":   "Age (s)"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Alias" }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Age (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 0.5  },
                    { "color": "red",    "value": 2    }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "All Signal Values",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_value",
          "legendFormat": "{{alias}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Signal Freshness — All",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_age_seconds",
          "legendFormat": "{{alias}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2    }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "$alias — Value",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_value{alias=\"$alias\"}",
          "legendFormat": "{{alias}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "$alias — Freshness",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_age_seconds{alias=\"$alias\"}",
          "legendFormat": "{{alias}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2    }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Device State & Status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_state",
          "refId": "A",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "expr": "control_system_attribute_status",
          "refId": "B",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "device",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "source": true, "source 1": true, "source 2": true,
              "attribute": true, "attribute 1": true, "attribute 2": true,
              "alias": true, "alias 1": true, "alias 2": true,
              "name": true, "name 1": true, "name 2": true,
              "Value": true, "Value 1": true, "Value 2": true
            },
            "indexByName": {
              "device": 0,
              "state":  1,
              "status": 2
            },
            "renameByName": {
              "device": "Device",
              "state":  "State",
              "status": "Status"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Device" }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "RUNNING": { "color": "green",  "text": "RUNNING", "index": 0 } } },
                  { "type": "value", "options": { "FAULT":   { "color": "red",    "text": "FAULT",   "index": 1 } } },
                  { "type": "value", "options": { "ALARM":   { "color": "orange", "text": "ALARM",   "index": 2 } } },
                  { "type": "value", "options": { "MOVING":  { "color": "blue",   "text": "MOVING",  "index": 3 } } },
                  { "type": "value", "options": { "STANDBY": { "color": "yellow", "text": "STANDBY", "index": 4 } } },
                  { "type": "value", "options": { "OFF":     { "color": "gray",   "text": "OFF",     "index": 5 } } },
                  { "type": "value", "options": { "ON":      { "color": "green",  "text": "ON",      "index": 6 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    }
  ]
}
