{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["status-server", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "title": "Status Server Health",
  "uid": "status-server-health",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Monitored Attributes",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "targets": [
        {
          "expr": "status_server_monitored_attributes",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max Signal Age",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "max(control_system_attribute_age_seconds)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2    }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Freshness by Source (max age)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "max by(source) (control_system_attribute_age_seconds)",
          "legendFormat": "{{source}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2    }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Up Attributes",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "status_server_up_attributes",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failed Attributes",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "status_server_failed_attributes",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Device State & Status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_state",
          "refId": "A",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "expr": "control_system_attribute_status",
          "refId": "B",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "device",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "source": true, "source 1": true, "source 2": true,
              "attribute": true, "attribute 1": true, "attribute 2": true,
              "alias": true, "alias 1": true, "alias 2": true,
              "name": true, "name 1": true, "name 2": true,
              "Value": true, "Value 1": true, "Value 2": true
            },
            "indexByName": {
              "device": 0,
              "state": 1,
              "status": 2
            },
            "renameByName": {
              "device": "Device",
              "state": "State",
              "status": "Status"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Device" }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "RUNNING": { "color": "green",  "text": "RUNNING", "index": 0 } } },
                  { "type": "value", "options": { "FAULT":   { "color": "red",    "text": "FAULT",   "index": 1 } } },
                  { "type": "value", "options": { "ALARM":   { "color": "orange", "text": "ALARM",   "index": 2 } } },
                  { "type": "value", "options": { "MOVING":  { "color": "blue",   "text": "MOVING",  "index": 3 } } },
                  { "type": "value", "options": { "STANDBY": { "color": "yellow", "text": "STANDBY", "index": 4 } } },
                  { "type": "value", "options": { "OFF":     { "color": "gray",   "text": "OFF",     "index": 5 } } },
                  { "type": "value", "options": { "ON":      { "color": "green",  "text": "ON",      "index": 6 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Failed Attributes",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "control_system_attribute_up == 0",
          "refId": "A",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true
            },
            "indexByName": {
              "alias":     0,
              "device":    1,
              "name":      2,
              "source":    3,
              "attribute": 4
            },
            "renameByName": {
              "alias":     "Alias",
              "device":    "Device",
              "name":      "Attribute",
              "source":    "Source",
              "attribute": "Full Path"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Device" }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    }
  ]
}
